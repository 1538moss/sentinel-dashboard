; Kopier denne filen til .sentinel.env ett nivå OPP fra webroot og fyll inn verdier:
;   Lokalt:  C:\xampp\htdocs\.sentinel.env
;   Server:  /var/www/.sentinel.env
;
; Filen skal ALDRI ligge inne i sentinel/-mappen eller committes til git.
; Generer FETCH_TOKEN med: php -r "echo bin2hex(random_bytes(24));"

SH_CLIENT_ID=your-client-id-here
SH_CLIENT_SECRET=your-client-secret-here
FETCH_TOKEN=your-random-token-here

; USGS M2M (Landsat 8-9) — https://ers.cr.usgs.gov/profile/access
USGS_USERNAME=your-usgs-username-here
USGS_M2M_TOKEN=your-usgs-m2m-token-here

; CDSE-kontopassord (Sentinel-3 LST-nedlasting via OData — IKKE samme som
; SH_CLIENT_ID/SECRET over). Bruk anførselstegn hvis passordet inneholder
; spesialtegn (!, #, ;, = o.l.), ellers feiler parse_ini_file.
; Kontoen må IKKE ha 2FA/TOTP slått på, siden dette kjøres uten tilsyn i cron.
CDSE_USERNAME=din-epost@eksempel.com
CDSE_PASSWORD="ditt-cdse-passord"
